# ─────────────────────────────────────────────────────────────────────
# The Wedding Sridha — what NOT to commit / deploy
# ─────────────────────────────────────────────────────────────────────

# ── OS / editor cruft ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log
*.swp
.vscode/
.idea/

# ── Local exports / backups (downloaded data.js you haven't deployed) ─
data-backup-*.js
*.bak

# ── Local server artefacts ──────────────────────────────────────────
.cache/
node_modules/
.netlify/

# ── Local env secrets (ADMIN_PASSWORD, ADMIN_SECRET) ────────────────
.env
.env.local
